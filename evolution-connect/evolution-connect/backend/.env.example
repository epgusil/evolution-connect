# Puerto en el que corre el servidor (Render lo asigna automáticamente)
PORT=4000

# URL(s) del frontend desplegado, separadas por coma si hay más de una
# (por ejemplo tu dominio de Vercel y un dominio de pruebas).
# En local puedes dejarlo en *, pero en producción usa la URL exacta.
FRONTEND_URL=https://tu-proyecto.vercel.app
